---
import AppFooter from '../components/AppFooter.astro';
import AppHeader from '../components/AppHeader.astro';
import FeatureSection from '../components/FeatureSection.astro';
import Hero from '../components/Hero.astro';
import ProfileSection from '../components/ProfileSection.astro';
import '../styles/global.css';

const title = 'DoveCli | 개인 개발자 KIM SANG WOO';
const description =
  'DoveCli is the official developer website for KIM SANG WOO, an independent developer creating simple, reliable apps and tools.';
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href="https://dovecli.com/" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0958e6" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dovecli.com/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://dovecli.com/assets/dove-cli-header.png" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <AppHeader />
    <main>
      <Hero />
      <FeatureSection />
      <ProfileSection />
    </main>
    <AppFooter />
  </body>
</html>
