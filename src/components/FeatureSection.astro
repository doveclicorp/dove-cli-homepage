---
const features = [
  {
    title: 'Mobile Apps',
    body: 'Cross-platform mobile apps with modern frameworks and great UX.',
    icon: 'phone',
  },
  {
    title: 'CLI Tools',
    body: 'Productive command-line tools that automate and simplify complex tasks.',
    icon: 'terminal',
  },
  {
    title: 'Clean Interfaces',
    body: 'Minimal, intuitive interfaces focused on clarity and excellent user experience.',
    icon: 'card',
  },
];
---

<section id="projects" class="feature-section section-shell" aria-label="Project categories">
  {
    features.map((feature) => (
      <article class="feature-item reveal">
        <div class="iso-icon" data-icon={feature.icon} aria-hidden="true">
          <span></span>
        </div>
        <div>
          <h2>{feature.title}</h2>
          <p>{feature.body}</p>
        </div>
      </article>
    ))
  }
</section>
