---
const skills = ['JavaScript', 'TypeScript', 'React', 'Node.js', 'CLI'];
---

<section id="about" class="profile-section section-shell" aria-label="About and contact">
  <article class="about-card reveal">
    <img src="/assets/dove-cli.png" alt="DoveCli mascot" />
    <div>
      <h2>About Me</h2>
      <p>
        I'm KIM SANG WOO, an independent developer.<br />
        I build simple, reliable, and maintainable apps and tools<br />
        that solve real problems and deliver value.
      </p>
      <div class="skill-list" aria-label="Skills">
        {skills.map((skill) => <span>{skill}</span>)}
      </div>
    </div>
  </article>

  <article id="contact" class="contact-card reveal">
    <h2>Get in Touch</h2>
    <p>
      Have a project in mind or want to say hello?<br />
      Feel free to reach out anytime.
    </p>
    <a href="mailto:doveclicorp@gmail.com">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <rect x="3" y="5" width="18" height="14" rx="2" />
        <path d="m3 7 9 7 9-7" />
      </svg>
      doveclicorp@gmail.com
    </a>
  </article>
</section>
